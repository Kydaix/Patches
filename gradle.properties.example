# Identifiants GitHub Packages (auth obligatoire même en lecture).
# Copie ces lignes dans le fichier Gradle GLOBAL (jamais commité) :
#   C:\Users\Administrator\.gradle\gradle.properties
# Token GitHub avec le scope read:packages -> https://github.com/settings/tokens
#
# La config (settings.gradle.kts) lit les credentials du repo "githubPackages" :
githubPackagesUsername=ton_pseudo_github
githubPackagesPassword=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
